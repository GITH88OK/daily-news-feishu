# ── 必填 ──
# 飞书机器人 Webhook URL
# 获取方式：飞书群 → 设置 → 群机器人 → 添加自定义机器人
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_here

# ── 可选 ──
# 天行数据 API Key（RSS全部失败时的兜底，不填也能用）
# 注册地址: https://www.tianapi.com/
# TIANAPI_KEY=your_tianapi_key_here

# RSSHub 实例地址（默认使用官方 rsshub.app，可自建以提高稳定性）
# RSSHUB_BASE=https://rsshub.app
